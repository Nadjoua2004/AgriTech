# Database
DATABASE_URL=postgresql://user:password@localhost/dbname

# App
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Mock switches (set to false when teammates are ready)
USE_MOCK_LAND=true
USE_MOCK_CULTURE=true
USE_MOCK_EQUIPMENT=true
USE_MOCK_AUTH=true

# Real service URLs (fill in when teammates deploy)
LAND_SERVICE_URL=http://land-service/api
CULTURE_SERVICE_URL=http://culture-service/api
EQUIPMENT_SERVICE_URL=http://equipment-service/api
AUTH_SERVICE_URL=http://auth-service/api

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost/
