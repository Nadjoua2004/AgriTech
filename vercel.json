{
  "version": 2,
  "builds": [
    {
      "src": "frontend/vercel_app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "services/auth_service/vercel_app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "services/cultures_service/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "services/equipment_service/vercel_app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "services/terre_service/vercel_app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "services/worker_service/vercel_app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "services/auth_service/vercel_app.py"
    },
    {
      "source": "/api/cultures/(.*)",
      "destination": "services/cultures_service/main.py"
    },
    {
      "source": "/api/equipment/(.*)",
      "destination": "services/equipment_service/vercel_app.py"
    },
    {
      "source": "/api/terre/(.*)",
      "destination": "services/terre_service/vercel_app.py"
    },
    {
      "source": "/api/worker/(.*)",
      "destination": "services/worker_service/vercel_app.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "frontend/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/vercel_app.py"
    }
  ]
}
